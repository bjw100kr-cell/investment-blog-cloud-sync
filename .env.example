# Investment Blog Cloud Sync
# Copy to `.env` when you are ready to connect local credentials.
# Values in `.env` do NOT automatically sync to GitHub Actions.

# --- Blog publishing core ---
# Required for real draft generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for Blogger draft upload
BLOGGER_BLOG_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
BLOGGER_SYNC_SITE_PAGES=false
BLOGGER_SITE_PAGES_PUBLISH=false
BLOGGER_INCLUDE_OPTIONAL_SITE_PAGES=false
BLOGGER_AUTO_PUBLISH_POSTS=false
BLOGGER_PUBLISH_ONLY_DUE_POSTS=true
BLOGGER_MAX_POSTS_PER_RUN=1

# Optional short-lived test token for Blogger
GOOGLE_ACCESS_TOKEN=

# Optional base URL for publish-ready internal links
BLOG_BASE_URL=

# Optional monetization stack
GA4_MEASUREMENT_ID=
ADSENSE_PUBLISHER_ID=
ADSENSE_SITE_VERIFICATION=
NEWSLETTER_SUBSCRIBE_URL=

# Naver DataLab
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Search Console
SEARCH_CONSOLE_SITE_URL=
SEARCH_CONSOLE_CLIENT_ID=
SEARCH_CONSOLE_CLIENT_SECRET=
SEARCH_CONSOLE_REFRESH_TOKEN=
SEARCH_CONSOLE_ACCESS_TOKEN=
SEARCH_CONSOLE_LAG_DAYS=3
SEARCH_CONSOLE_WINDOW_DAYS=7

# Google OAuth helper
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/oauth2callback
GOOGLE_OAUTH_PRESET=combined
GOOGLE_OAUTH_OPEN_BROWSER=false
